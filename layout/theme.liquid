	    <script>
	        $(document).ready(function() {
	          var owl = $('.the_velvet-slider.owl-carousel');
	          owl.owlCarousel({
	            margin: 0,
	            nav: true,
	            dot: false,
	            loop: true,
	            animateOut: 'fadeOut',
