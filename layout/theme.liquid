	            autoplayTimeout:10000,
	            autoplayHoverPause:false,
	            responsive: {
	              0: {
	                items: 1
	              },
	              600: {
	                items: 1
	              },
	              1000: {
	                items: 1
	              }
	            }
	          })
	        })

	        $(document).ready(function() {
	          var owl = $('.owl-carousel');
	          owl.owlCarousel({
	            margin: 0,
	            nav: false,
	            dot: true,
	            loop: true,
	            responsive: {
	              0: {
	                items: 1
	              },
	              600: {
	                items: 1
	              },
	              1000: {
	                items: 1
	              }
	            }
	          })
	        })

	        // Wrap every letter in a span
	        var textWrapper = document.querySelector('.diveinto-text-inner h2');
	        textWrapper.innerHTML = textWrapper.textContent.replace(/\S/g, "<span class='letter'>$&</span>");

	        anime.timeline({loop: true})
	          .add({
	            targets: '.diveinto-text-inner h2 .letter',
	            opacity: [0,1],
	            easing: "easeInOutQuad",
	            duration: 400,
	            delay: (el, i) => 100 * (i+1)
	          }).add({
	            targets: '.diveinto-text-inner h2',
	            opacity: 1,
	            duration: 0,
	            easing: "easeOutExpo",
	            delay: 0
	          });
	    </script>
	{% endif %}

