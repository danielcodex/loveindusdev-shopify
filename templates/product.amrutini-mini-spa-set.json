      "type": "faq",
      "blocks": {
        "question_rhYkEn": {
          "type": "question",
          "settings": {
            "title": "What skin types is the Mini Spa Set suitable for?",
            "text": "<p>All skin types — even sensitive. The serum absorbs instantly, and the cream nourishes deeply without feeling heavy.</p>"
          }
        },
        "question_DYwHbp": {
          "type": "question",
          "settings": {
            "title": "Can I layer makeup after using these products?",
            "text": "<p>Absolutely. The fast-absorbing serum is the perfect primer, and the cream creates a smooth, hydrated base for flawless makeup application.</p>"
          }
        },
        "question_MDCehx": {
          "type": "question",
          "settings": {
            "title": " What are Copper-Crusted Silk Cocoons?",
            "text": "<p>Raw silk cocoons infused with copper — prized for their antioxidant and collagen-supporting benefits. They gently exfoliate while delivering protein and copper to refine texture and support youthful skin.</p>"
          }
        }
      },
