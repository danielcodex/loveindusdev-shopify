{% comment %}
  Snippet: mmx-trust-badges
  Description: Reusable row of trust/guarantee badges

  Usage:
    {% render 'mmx-trust-badges',
      items: trust_items_array,
      color: '#1B1F8A',
      size: 'small'
    %}

  Parameters:
    - color: String — icon and text color (default: '#1B1F8A')
    - size: String — 'small' | 'large' (default: 'small')
    - items: Array — array of strings (rendered via Liquid assign)

  Note: Since Liquid doesn't support passing arrays directly to snippets,
  use the inline version below for custom items, or use the default set.
{% endcomment %}

{% assign badge_color = color | default: '#1B1F8A' %}
{% assign badge_size = size | default: 'small' %}

<div class="mmx-trust-badges mmx-trust-badges--{{ badge_size }}" role="list" aria-label="Trust guarantees">
  <div class="mmx-trust-badges__item" role="listitem" style="color: {{ badge_color }};">
    <svg class="mmx-trust-badges__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    <span>30-Day Guarantee</span>
  </div>
  <div class="mmx-trust-badges__item" role="listitem" style="color: {{ badge_color }};">
    <svg class="mmx-trust-badges__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    <span>Free US Shipping $75+</span>
  </div>
  <div class="mmx-trust-badges__item" role="listitem" style="color: {{ badge_color }};">
    <svg class="mmx-trust-badges__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>
    <span>Easy Returns</span>
  </div>
  <div class="mmx-trust-badges__item" role="listitem" style="color: {{ badge_color }};">
    <svg class="mmx-trust-badges__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    <span>Clean Formula</span>
  </div>
</div>

<style>
  .mmx-trust-badges {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .mmx-trust-badges__item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mmx-font-sans);
    font-weight: 500;
    opacity: 0.7;
  }

  .mmx-trust-badges--small .mmx-trust-badges__item {
    font-size: 11px;
  }

  .mmx-trust-badges--large .mmx-trust-badges__item {
    font-size: 13px;
  }

  .mmx-trust-badges__icon {
    flex-shrink: 0;
  }

  .mmx-trust-badges--small .mmx-trust-badges__icon {
    width: 14px;
    height: 14px;
  }

  .mmx-trust-badges--large .mmx-trust-badges__icon {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 600px) {
    .mmx-trust-badges {
      gap: 16px;
    }

    .mmx-trust-badges__item span {
      display: none;
    }

    .mmx-trust-badges__item {
      flex-direction: column;
      gap: 4px;
      opacity: 0.6;
    }

    .mmx-trust-badges__item span {
      display: block;
      font-size: 9px;
      text-align: center;
    }
  }
</style>
