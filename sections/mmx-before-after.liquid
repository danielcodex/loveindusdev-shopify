{% comment %}
  Section: mmx-before-after
  Description: Before/after image slider with clinical stats
{% endcomment %}

<style>
  .mmx-before-after {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  /*
   * Desktop grid: 3 named areas
   *   [header]  [slider]
   *   [stats ]  [slider]
   */
  .mmx-before-after__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "header slider"
      "stats  slider";
    gap: 0 80px;
    align-items: start;
  }

  /* ── Header card (left-top) ── */
  .mmx-before-after__header-card {
    grid-area: header;
    background-color: #F8F3EE;
    border-radius: 20px;
    padding: 29px 32px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 13px;
    margin-bottom: 40px;
  }

  .mmx-before-after__header-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mmx-font-sans);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 2.2px;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
  }

  .mmx-before-after__header-eyebrow svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .mmx-before-after__header-divider {
    width: 40px;
    height: 2px;
    background-color: {{ section.settings.accent_color }};
  }

  .mmx-before-after__header-headline {
    font-family: var(--mmx-font-sans);
    font-size: 24px;
    font-weight: 500;
    letter-spacing: 0.6px;
    color: {{ section.settings.headline_color }};
    margin: 0;
    line-height: 1.15;
  }

  .mmx-before-after__header-subtext {
    font-family: var(--mmx-font-sans);
    font-size: 18px;
    color: #6B6E73;
    margin: 0;
    line-height: 1.33;
  }

  /* ── Stats section (left-bottom) ── */
  .mmx-before-after__stats-wrap {
    grid-area: stats;
  }

  .mmx-before-after__stats-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mmx-font-sans);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 2.2px;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: 16px;
  }

  .mmx-before-after__stats-eyebrow svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .mmx-before-after__stats-divider {
    width: 36px;
    height: 2px;
    background-color: {{ section.settings.accent_color }};
    margin-bottom: 20px;
  }

  .mmx-before-after__stats-headline {
    font-family: var(--mmx-font-sans);
    font-size: 28px;
    font-weight: 700;
    color: {{ section.settings.headline_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .mmx-before-after__stats-body {
    font-family: var(--mmx-font-sans);
    font-size: 16px;
    line-height: 1.594;
    color: #6B6E73;
    margin-bottom: 24px;
  }

  .mmx-before-after__stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  .mmx-before-after__stat-card {
    background-color: #FFFFFF;
    border: 1px solid rgba(0, 25, 159, 0.1);
    border-radius: 14px;
    padding: 20px 16px;
    box-shadow: 0px 4px 16px 0px rgba(0, 25, 159, 0.06);
  }

  .mmx-before-after__stat-number {
    font-family: var(--mmx-font-sans);
    font-size: 32px;
    font-weight: 700;
    color: {{ section.settings.headline_color }};
    line-height: 1;
    margin-bottom: 6px;
  }

  .mmx-before-after__stat-label {
    font-family: var(--mmx-font-sans);
    font-size: 16px;
    color: #6B6E73;
    line-height: 1.05;
  }

  .mmx-before-after__study-note {
    background-color: rgba(0, 25, 159, 0.05);
    border: 1px solid rgba(0, 25, 159, 0.1);
    border-radius: 12px;
    padding: 16px;
    font-family: var(--mmx-font-sans);
    font-size: 16px;
    line-height: 1.44;
    color: #6B6E73;
  }

  .mmx-before-after__study-note strong {
    color: {{ section.settings.headline_color }};
    font-weight: 700;
  }

  /* ── Slider (right column) ── */
  .mmx-before-after__slider-wrap {
    grid-area: slider;
  }

  mmx-before-after-slider {
    display: block;
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    cursor: col-resize;
    user-select: none;
    touch-action: pan-y;
    box-shadow: 0px 24px 64px 0px rgba(0, 25, 159, 0.13);
  }

  .mmx-ba-slider__container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
  }

  .mmx-ba-slider__after {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mmx-ba-slider__before-wrap {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    overflow: hidden;
    width: 50%;
  }

  .mmx-ba-slider__before {
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    top: 0;
    left: 0;
  }

  /* Handle: vertical line + circle */
  .mmx-ba-slider__handle {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 44px;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 10;
    pointer-events: none;
  }

  .mmx-ba-slider__handle-line {
    width: 3px;
    flex: 1;
    background-color: #ffffff;
    box-shadow: 0px 0px 16px 0px rgba(0, 0, 0, 0.4);
  }

  .mmx-ba-slider__handle-circle {
    width: 44px;
    height: 44px;
    border-radius: 22px;
    background-color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0px 4px 20px 0px rgba(0, 0, 0, 0.25);
    flex-shrink: 0;
  }

  .mmx-ba-slider__handle-circle svg {
    width: 18px;
    height: 18px;
  }

  /* Labels */
  .mmx-ba-slider__label {
    position: absolute;
    top: 16px;
    height: 34px;
    display: flex;
    align-items: center;
    padding: 0 14px;
    border-radius: 100px;
    font-family: var(--mmx-font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.32px;
    text-transform: uppercase;
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }

  .mmx-ba-slider__label--before {
    left: 16px;
    background-color: rgba(0, 0, 0, 0.55);
    color: #ffffff;
  }

  .mmx-ba-slider__label--after {
    right: 16px;
    background-color: #ffffff;
    color: {{ section.settings.headline_color }};
  }

  .mmx-before-after__caption {
    font-family: var(--mmx-font-sans);
    font-size: 20px;
    color: #9CA3AF;
    text-align: left;
    margin-top: 16px;
    margin-bottom: 0;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .mmx-before-after {
      padding: {{ section.settings.mobile_padding_top }}px 0 {{ section.settings.mobile_padding_bottom }}px;
    }

    .mmx-before-after__inner {
      display: flex;
      flex-direction: column;
      gap: 32px;
      padding: 0 20px;
    }

    .mmx-before-after__header-card {
      /* On mobile: no card background, just centered text */
      background-color: transparent;
      border-radius: 0;
      padding: 0;
      margin-bottom: 0;
      gap: 0;
    }

    .mmx-before-after__header-eyebrow {
      font-size: 11px;
      letter-spacing: 2.2px;
      margin-bottom: 8px;
    }

    .mmx-before-after__header-divider {
      margin: 8px auto;
    }

    .mmx-before-after__header-headline {
      font-size: 20px;
      letter-spacing: 0.5px;
      color: #212326;
      margin-top: 8px;
    }

    .mmx-before-after__header-subtext {
      font-size: 16px;
      margin-top: 8px;
    }

    .mmx-before-after__stats-eyebrow {
      font-size: 13px;
      letter-spacing: 1.69px;
    }

    .mmx-before-after__stats-headline {
      font-size: 20px;
      color: #212326;
    }

    .mmx-before-after__stats-body {
      font-size: 14px;
    }

    .mmx-before-after__stat-number {
      font-size: 24px;
    }

    .mmx-before-after__stat-label {
      font-size: 12px;
    }

    .mmx-before-after__study-note {
      font-size: 12px;
    }

    .mmx-before-after__caption {
      font-size: 11px;
      color: #4C4D4D;
      text-align: center;
      margin-top: 12px;
    }
  }
</style>

<section class="mmx-before-after" id="mmx-before-after">
  <div class="mmx-before-after__inner">

    <!-- LEFT TOP: Header card -->
    <div class="mmx-before-after__header-card">
      <div class="mmx-before-after__header-eyebrow">
        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 2V3.33333M8 12.6667V14M2 8H3.33333M12.6667 8H14" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
          <path opacity="0.6" d="M3.75733 3.75733L4.7 4.7M11.3 11.3L12.2427 12.2427M3.75733 12.2427L4.7 11.3M11.3 4.7L12.2427 3.75733" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M8 10.6667C9.47276 10.6667 10.6667 9.47276 10.6667 8C10.6667 6.52724 9.47276 5.33333 8 5.33333C6.52724 5.33333 5.33333 6.52724 5.33333 8C5.33333 9.47276 6.52724 10.6667 8 10.6667Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ section.settings.slider_eyebrow }}
      </div>
      <div class="mmx-before-after__header-divider" aria-hidden="true"></div>
      <h2 class="mmx-before-after__header-headline">{{ section.settings.slider_headline }}</h2>
      <p class="mmx-before-after__header-subtext">{{ section.settings.slider_subtext }}</p>
    </div>

    <!-- RIGHT: Slider image -->
    <div class="mmx-before-after__slider-wrap">
      <mmx-before-after-slider aria-label="Before and after skin comparison slider">
        <div class="mmx-ba-slider__container">
          {% if section.settings.after_image != blank %}
            <img
              src="{{ section.settings.after_image | image_url: width: 700 }}"
              alt="After 28 days of using Amrutini Luminosity Dewdrops"
              class="mmx-ba-slider__after"
              loading="lazy"
              width="560"
              height="700"
            >
          {% else %}
            <img
              src="https://files.manuscdn.com/user_upload_by_module/session_file/310519663397914943/bJVOnVSrjkDRBgGo.jpg"
              alt="After 28 days of using Amrutini Luminosity Dewdrops"
              class="mmx-ba-slider__after"
              loading="lazy"
              width="560"
              height="700"
            >
          {% endif %}

          <div class="mmx-ba-slider__before-wrap" data-before-wrap>
            {% if section.settings.before_image != blank %}
              <img
                src="{{ section.settings.before_image | image_url: width: 700 }}"
                alt="Before using Amrutini Luminosity Dewdrops"
                class="mmx-ba-slider__before"
                loading="lazy"
                width="560"
                height="700"
              >
            {% else %}
              <img
                src="https://files.manuscdn.com/user_upload_by_module/session_file/310519663397914943/XpGfLNCLhmFpctTt.jpg"
                alt="Before using Amrutini Luminosity Dewdrops"
                class="mmx-ba-slider__before"
                loading="lazy"
                width="560"
                height="700"
              >
            {% endif %}
          </div>

          <div class="mmx-ba-slider__handle" data-handle aria-hidden="true">
            <div class="mmx-ba-slider__handle-line"></div>
            <div class="mmx-ba-slider__handle-circle">
              <svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 4L2 9L6 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 4L16 9L12 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="mmx-ba-slider__handle-line"></div>
          </div>

          <span class="mmx-ba-slider__label mmx-ba-slider__label--before">BEFORE</span>
          <span class="mmx-ba-slider__label mmx-ba-slider__label--after">AFTER 28 DAYS</span>
        </div>
      </mmx-before-after-slider>

      <p class="mmx-before-after__caption">← Drag to compare · Clinical study, n=36, 28-day independent trial</p>
    </div>

    <!-- LEFT BOTTOM: Stats -->
    <div class="mmx-before-after__stats-wrap">
      <div class="mmx-before-after__stats-eyebrow">
        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 9.33333C10.2091 9.33333 12 7.54247 12 5.33333C12 3.12419 10.2091 1.33333 8 1.33333C5.79086 1.33333 4 3.12419 4 5.33333C4 7.54247 5.79086 9.33333 8 9.33333Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M10.318 8.59333L11.3333 14.6667L8 12.6667L4.66667 14.6667L5.682 8.59333" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ section.settings.stats_eyebrow }}
      </div>
      <div class="mmx-before-after__stats-divider" aria-hidden="true"></div>

      <h2 class="mmx-before-after__stats-headline">{{ section.settings.stats_headline }}</h2>
      <p class="mmx-before-after__stats-body">{{ section.settings.stats_body }}</p>

      <div class="mmx-before-after__stats-grid">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div class="mmx-before-after__stat-card" {{ block.shopify_attributes }}>
              <div class="mmx-before-after__stat-number">{{ block.settings.number }}</div>
              <div class="mmx-before-after__stat-label">{{ block.settings.label }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.settings.study_note != blank %}
        <div class="mmx-before-after__study-note">
          <strong>Study details:</strong> {{ section.settings.study_note }}
        </div>
      {% endif %}
    </div>

  </div>
</section>

<script>
  (function() {
    if (customElements.get('mmx-before-after-slider')) return;

    class MMXBeforeAfterSlider extends HTMLElement {
      connectedCallback() {
        this._container = this.querySelector('.mmx-ba-slider__container');
        this._beforeWrap = this.querySelector('[data-before-wrap]');
        this._beforeImg = this.querySelector('.mmx-ba-slider__before');
        this._handle = this.querySelector('[data-handle]');
        this._dragging = false;
        this._position = 50;

        this.addEventListener('mousedown', this._onStart.bind(this));
        this.addEventListener('touchstart', this._onStart.bind(this), { passive: true });
        this._boundMove = this._onMove.bind(this);
        this._boundEnd = this._onEnd.bind(this);
        window.addEventListener('mousemove', this._boundMove);
        window.addEventListener('touchmove', this._boundMove, { passive: false });
        window.addEventListener('mouseup', this._boundEnd);
        window.addEventListener('touchend', this._boundEnd);

        this._resizeObserver = new ResizeObserver(() => this._render());
        this._resizeObserver.observe(this._container);

        this._render();
      }

      disconnectedCallback() {
        window.removeEventListener('mousemove', this._boundMove);
        window.removeEventListener('touchmove', this._boundMove);
        window.removeEventListener('mouseup', this._boundEnd);
        window.removeEventListener('touchend', this._boundEnd);
        if (this._resizeObserver) this._resizeObserver.disconnect();
      }

      _getX(e) {
        return e.touches ? e.touches[0].clientX : e.clientX;
      }

      _onStart(e) {
        this._dragging = true;
        this._onMove(e);
      }

      _onMove(e) {
        if (!this._dragging) return;
        if (e.cancelable) e.preventDefault();

        const rect = this.getBoundingClientRect();
        const x = this._getX(e) - rect.left;
        this._position = Math.max(0, Math.min(100, (x / rect.width) * 100));
        this._render();
      }

      _onEnd() {
        this._dragging = false;
      }

      _render() {
        if (this._beforeWrap) {
          this._beforeWrap.style.width = this._position + '%';
        }
        if (this._handle) {
          this._handle.style.left = this._position + '%';
        }
        if (this._beforeImg && this._container) {
          this._beforeImg.style.width = this._container.offsetWidth + 'px';
        }
      }
    }

    customElements.define('mmx-before-after-slider', MMXBeforeAfterSlider);
  })();
</script>

{% schema %}
{
  "name": "MMX Before/After",
  "tag": "div",
  "class": "mmx-section-before-after",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FAF9F8"
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Headline / Text Color",
      "default": "#00199F"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#00199F"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#00199F"
    },
    {
      "type": "text",
      "id": "slider_eyebrow",
      "label": "Slider Eyebrow",
      "default": "CLINICAL RESULTS"
    },
    {
      "type": "text",
      "id": "slider_headline",
      "label": "Slider Headline",
      "default": "See the Transformation"
    },
    {
      "type": "text",
      "id": "slider_subtext",
      "label": "Slider Subtext",
      "default": "Real results from a 28-day clinical study. Drag the slider to reveal the difference."
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before Image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After Image"
    },
    {
      "type": "text",
      "id": "stats_eyebrow",
      "label": "Stats Eyebrow",
      "default": "CLINICALLY PROVEN"
    },
    {
      "type": "text",
      "id": "stats_headline",
      "label": "Stats Headline",
      "default": "Radical Radiance, Backed by Science"
    },
    {
      "type": "textarea",
      "id": "stats_body",
      "label": "Stats Body",
      "default": "In an independent 28-day clinical trial, women using Amrutini® Luminosity Dewdrops reported transformative results — not just in how their skin looked, but how it felt."
    },
    {
      "type": "textarea",
      "id": "study_note",
      "label": "Study Details Footnote",
