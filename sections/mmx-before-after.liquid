      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom (px)",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Clinical Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Stat Number",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Stat Label",
          "default": "Saw improved skin radiance"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MMX Before/After",
      "blocks": [
        { "type": "stat", "settings": { "number": "100%", "label": "Saw improved skin radiance" } },
        { "type": "stat", "settings": { "number": "94%",  "label": "Reported visibly smoother skin" } },
        { "type": "stat", "settings": { "number": "89%",  "label": "Noticed reduced dark spots" } },
        { "type": "stat", "settings": { "number": "28 days", "label": "Average time to visible results" } }
      ]
    }
  ]
}
{% endschema %}
