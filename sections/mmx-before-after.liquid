    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 96
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top (px)",
      "min": 20,
