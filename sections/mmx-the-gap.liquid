{% comment %}
  Section: mmx-the-gap
  Description: Problem statement / "The Gap" section with pull quote
{% endcomment %}

<style>
  .mmx-the-gap {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .mmx-the-gap__inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 40px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mmx-the-gap__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mmx-font-sans);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 2.2px;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
  }

  .mmx-the-gap__eyebrow-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .mmx-the-gap__eyebrow-line {
    display: block;
    width: 40px;
    height: 2px;
    background-color: {{ section.settings.accent_color }};
    margin-top: 20px;
  }

  .mmx-the-gap__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    margin-top: 35px;
    text-align: center;
  }

  .mmx-the-gap__body {
    font-family: var(--mmx-font-sans);
    font-size: 22px;
    font-style: italic;
    line-height: 1.8;
    color: {{ section.settings.body_color }};
    max-width: 582px;
    margin: 0;
  }

  .mmx-the-gap__pull-quote {
    font-family: var(--mmx-font-sans);
    font-size: 20px;
    font-weight: 700;
    font-style: normal;
    line-height: 1.8;
    color: {{ section.settings.quote_color }};
    max-width: 761px;
    margin: 0;
    padding: 0;
    border: none;
  }

  @media (max-width: 768px) {
    .mmx-the-gap {
      padding: {{ section.settings.mobile_padding_top }}px 0 {{ section.settings.mobile_padding_bottom }}px;
    }

    .mmx-the-gap__inner {
      padding: 0 24px;
    }

    .mmx-the-gap__eyebrow {
      font-size: 13px;
      letter-spacing: 1.69px;
    }

    .mmx-the-gap__body {
      font-size: 15px;
      line-height: 2.04;
      color: {{ section.settings.body_color_mobile }};
      max-width: 335px;
    }

    .mmx-the-gap__pull-quote {
      font-size: 15px;
      line-height: 1.92;
      max-width: 341px;
    }
  }
</style>

<section class="mmx-the-gap" id="mmx-the-gap">
  <div class="mmx-the-gap__inner">
    <div class="mmx-the-gap__eyebrow">
      <svg class="mmx-the-gap__eyebrow-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M8 1.33333C8 1.33333 3.33333 6.33333 3.33333 9.66667C3.33333 10.9043 3.825 12.0913 4.70017 12.9665C5.57534 13.8417 6.76232 14.3333 8 14.3333C9.23768 14.3333 10.4247 13.8417 11.2998 12.9665C12.175 12.0913 12.6667 10.9043 12.6667 9.66667C12.6667 6.33333 8 1.33333 8 1.33333Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
        <path opacity="0.5" d="M6 10.3333C6.06086 10.65 6.19738 10.9472 6.39793 11.1998C6.59848 11.4523 6.85711 11.6525 7.15178 11.7835C7.44645 11.9145 7.76841 11.9722 8.09023 11.9519C8.41204 11.9315 8.72417 11.8337 9 11.6667" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {{ section.settings.eyebrow_text }}
    </div>
    <span class="mmx-the-gap__eyebrow-line" aria-hidden="true"></span>

    <div class="mmx-the-gap__content">
      {% if section.settings.body_text != blank %}
        <p class="mmx-the-gap__body">
          {{ section.settings.body_text }}
        </p>
      {% endif %}

      {% if section.settings.pull_quote != blank %}
        <blockquote class="mmx-the-gap__pull-quote">
          {{ section.settings.pull_quote }}
        </blockquote>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MMX The Gap",
  "tag": "div",
  "class": "mmx-section-the-gap",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FAF9F8"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#00199F"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Line Color",
      "default": "#00199F"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body Text Color",
      "default": "#00199F"
    },
    {
      "type": "color",
      "id": "body_color_mobile",
      "label": "Body Text Color (Mobile)",
      "default": "#212326"
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Pull Quote Color",
      "default": "#00199F"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "THE GAP"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "\"You've tried the hyaluronic acids, the vitamin C serums, the retinol night creams. Your shelf is full of half-used bottles that promised radiance and delivered... fine.\""
    },
    {
      "type": "textarea",
      "id": "pull_quote",
      "label": "Pull Quote",
      "default": "\"What if the most potent ingredients for your skin have never been seen in Western skincare — sourced from the rarest corners of India, bio-engineered in New York City, and precision-formulated for clinical results?\""
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 112
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding Top (px)",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding Bottom (px)",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "MMX The Gap"
    }
  ]
}
{% endschema %}
