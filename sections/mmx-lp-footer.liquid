{% comment %}
  Section: mmx-lp-footer
  Description: Minimal LP footer with logo image, links, and copyright
{% endcomment %}

<style>
  .mmx-lp-footer {
    background-color: {{ section.settings.background_color }};
    padding: 0;
  }

  .mmx-lp-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 128px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 126px;
  }

  .mmx-lp-footer__logo {
    display: block;
    flex-shrink: 0;
  }

  .mmx-lp-footer__logo img {
    display: block;
    width: 80px;
    height: auto;
  }

  .mmx-lp-footer__links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .mmx-lp-footer__link {
    font-family: var(--mmx-font-sans);
    font-size: 12px;
    color: {{ section.settings.text_color }};
    text-decoration: none;
    letter-spacing: 0.96px;
    line-height: 18px;
    transition: opacity 0.2s;
  }

  .mmx-lp-footer__link:hover {
    opacity: 0.7;
  }

  .mmx-lp-footer__copyright {
    font-family: var(--mmx-font-sans);
    font-size: 12px;
    color: {{ section.settings.text_color }};
    line-height: 18px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .mmx-lp-footer__inner {
      flex-direction: column;
      justify-content: center;
      gap: 24px;
      height: auto;
      padding: 40px 24px;
      text-align: center;
    }

    .mmx-lp-footer__logo img {
      width: 100px;
    }

    .mmx-lp-footer__links {
      gap: 28px;
    }

    .mmx-lp-footer__link {
      font-size: 13px;
    }

    .mmx-lp-footer__copyright {
      font-size: 12px;
      opacity: 0.8;
    }
  }
</style>

<footer class="mmx-lp-footer" role="contentinfo">
  <div class="mmx-lp-footer__inner">
    <a href="{{ section.settings.logo_url | default: '/' }}" class="mmx-lp-footer__logo">
      {% if section.settings.logo_image != blank %}
        <img
          src="{{ section.settings.logo_image | image_url: width: 200 }}"
          alt="{{ section.settings.brand_name }}"
          loading="lazy"
          width="80"
          height="30"
        >
      {% else %}
        <img
          src="https://files.manuscdn.com/user_upload_by_module/session_file/310519663397914943/bJVOnVSrjkDRBgGo.jpg"
          alt="{{ section.settings.brand_name }}"
          loading="lazy"
          width="80"
          height="30"
          style="object-fit: contain;"
        >
      {% endif %}
    </a>

    <nav class="mmx-lp-footer__links" aria-label="Footer navigation">
      {% for block in section.blocks %}
        {% if block.type == 'link' %}
          <a
            href="{{ block.settings.url }}"
            class="mmx-lp-footer__link"
            {{ block.shopify_attributes }}
          >{{ block.settings.label }}</a>
        {% endif %}
      {% endfor %}
    </nav>

    <p class="mmx-lp-footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}. All rights reserved.
    </p>
  </div>
</footer>

{% schema %}
{
  "name": "MMX LP Footer",
  "tag": "div",
  "class": "mmx-section-lp-footer",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#00199F"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "url",
      "id": "logo_url",
      "label": "Logo URL"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "Love, Indus"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Footer Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Link Label",
          "default": "Privacy Policy"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MMX LP Footer",
      "blocks": [
        { "type": "link", "settings": { "label": "Shipping & Returns" } },
        { "type": "link", "settings": { "label": "Privacy Policy" } },
        { "type": "link", "settings": { "label": "Contact Us" } }
      ]
    }
  ]
}
{% endschema %}
